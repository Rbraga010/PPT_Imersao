{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/imersao-hai-slides.html" },
    { "source": "/slides", "destination": "/imersao-hai-slides.html" },
    { "source": "/briefing", "destination": "/imersao-hai-briefing.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
